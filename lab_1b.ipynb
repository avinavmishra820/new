    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "cr=pd.read_csv(\"cars.csv\")\n",
    "x=cr['Age']\n",
    "y=cr['Price']\n",
    "fig,ax=plt.subplots()\n",
    "plt.scatter(x,y,color=\"red\",marker=\"^\",s=20)\n",
    "plt.xlabel(\"Age\")\n",
    "plt.ylabel(\"Price\")\n",
    "plt.title(\"1NT22CS002 Aashutosh\")"
   ]
